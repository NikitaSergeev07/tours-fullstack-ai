{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "permissions": {
    "allow": [
      "Bash(ls *)",
      "Bash(cat *)",
      "Bash(rg *)",
      "Bash(grep *)",
      "Bash(curl *)",
      "Bash(docker compose ps *)",
      "Bash(docker compose logs *)",
      "Bash(docker compose exec backend php artisan *)",
      "Bash(docker compose exec backend ./vendor/bin/pint *)",
      "Bash(docker compose exec frontend npm run *)",
      "Bash(docker compose build *)",
      "Bash(docker compose up *)",
      "Bash(docker compose down)",
      "Bash(make *)",
      "Bash(php artisan *)",
      "Bash(composer install *)",
      "Bash(npm install *)",
      "Bash(npm run *)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(docker compose down -v *)",
      "Bash(git push --force *)",
      "Bash(git reset --hard *)"
    ]
  },
  "hooks": {
    "PostToolUse": [
      {
        "matcher": "Edit|Write|MultiEdit",
        "hooks": [
          {
            "type": "command",
            "command": ".claude/hooks/format-on-save.sh"
          }
        ]
      }
    ]
  }
}
