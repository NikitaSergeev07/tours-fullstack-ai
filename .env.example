# Application
APP_ENV=local
APP_URL=http://localhost:8000
APP_KEY=

# Database
DB_DATABASE=tours
DB_USERNAME=tours
DB_PASSWORD=tours_secret
DB_PORT=5432

# Service ports
BACKEND_PORT=8000
FRONTEND_PORT=3000
EMBEDDINGS_PORT=8001

# Embeddings
EMBEDDINGS_MODEL=sentence-transformers/paraphrase-multilingual-MiniLM-L12-v2

# LLM (used for tour autogeneration in the admin).
# Two auth modes:
#   - Direct Anthropic API:           set ANTHROPIC_API_KEY     (sent as `x-api-key`)
#   - Anthropic-compatible proxy:     set ANTHROPIC_AUTH_TOKEN  (sent as `Authorization: Bearer …`)
# If both are set, ANTHROPIC_AUTH_TOKEN wins.
# ANTHROPIC_BASE_URL must include the version segment (`/v1`).
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-haiku-4-5

# Yandex Maps JS API key (frontend) - get one at https://developer.tech.yandex.ru/
YANDEX_MAPS_API_KEY=

# Frontend
NODE_ENV=development
PUBLIC_API_URL=http://localhost:8000/api
