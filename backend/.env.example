APP_NAME="Tours"
APP_ENV=local
APP_KEY=
APP_DEBUG=true
APP_TIMEZONE=UTC
APP_URL=http://localhost:8000

APP_LOCALE=ru
APP_FALLBACK_LOCALE=en
APP_FAKER_LOCALE=ru_RU

APP_MAINTENANCE_DRIVER=file
APP_MAINTENANCE_STORE=database

BCRYPT_ROUNDS=12

LOG_CHANNEL=stack
LOG_STACK=single
LOG_DEPRECATIONS_CHANNEL=null
LOG_LEVEL=debug

DB_CONNECTION=pgsql
DB_HOST=postgres
DB_PORT=5432
DB_DATABASE=tours
DB_USERNAME=tours
DB_PASSWORD=tours_secret

SESSION_DRIVER=database
SESSION_LIFETIME=120
SESSION_ENCRYPT=false
SESSION_PATH=/
SESSION_DOMAIN=null

BROADCAST_CONNECTION=log
FILESYSTEM_DISK=public
QUEUE_CONNECTION=sync

CACHE_STORE=database
CACHE_PREFIX=

MEMCACHED_HOST=127.0.0.1

REDIS_CLIENT=phpredis
REDIS_HOST=127.0.0.1
REDIS_PASSWORD=null
REDIS_PORT=6379

MAIL_MAILER=log

VITE_APP_NAME="${APP_NAME}"

# Embeddings + LLM
EMBEDDINGS_URL=http://embeddings:8000
EMBEDDINGS_DIM=384

# Two auth modes for the Anthropic Messages API:
#   - Direct:     set ANTHROPIC_API_KEY    (header: `x-api-key`)
#   - Via proxy:  set ANTHROPIC_AUTH_TOKEN (header: `Authorization: Bearer …`)
# ANTHROPIC_AUTH_TOKEN wins if both are set. ANTHROPIC_BASE_URL must include `/v1`.
LLM_PROVIDER=anthropic
ANTHROPIC_API_KEY=
ANTHROPIC_AUTH_TOKEN=
ANTHROPIC_BASE_URL=https://api.anthropic.com/v1
ANTHROPIC_MODEL=claude-haiku-4-5
YANDEX_MAPS_API_KEY=

# CORS
FRONTEND_URL=http://localhost:3000

# Filament admin (seeded user)
ADMIN_EMAIL=admin@tours.local
ADMIN_PASSWORD=password
